DATABASE_URL=postgresql://postgres:postgres@localhost:5432/consultation
NETWORK_ID=2

# Docker deployment — domains & TLS
APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com
CERTBOT_EMAIL=admin@example.com
CERTBOT_STAGING=0

# Consultation dApp build args
VITE_PUBLIC_DAPP_DEFINITION_ADDRESS=
VITE_PUBLIC_NETWORK_ID=2

# Postgres configuration
POSTGRRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=consultation
POSTGRES_PORT=5432